---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

// Props each page can pass in. `title` and `description` are per-page;
// `jsonLd` is an optional array of schema.org objects for SEO/GEO.
const {
  title = 'Empower Complete Care Psychiatry — Bloomingdale, IL',
  description = 'Evidence-based, complete-care psychiatry in Bloomingdale, IL. Beyond medication management.',
  jsonLd = [],
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/assets/images/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,400;0,500;0,600;1,400&family=Outfit:wght@300;400;500;600&display=swap"
    rel="stylesheet"
  />
  <link rel="stylesheet" href="/assets/css/styles.css" />

  {jsonLd.map((block) => (
    <script type="application/ld+json" set:html={JSON.stringify(block)} />
  ))}

  <slot name="head" />
</head>
<body>
  <div class="page-bg" aria-hidden="true"></div>

  <Nav />

  <main>
    <slot />
  </main>

  <Footer />

  <script is:inline src="/assets/js/main.js"></script>
</body>
</html>
