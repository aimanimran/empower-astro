const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "MedicalWebPage",
    "name": "Dementia & Cognitive Health",
    "description": "Educational information about memory concerns, caregiving, aging-related mental health, and cognitive wellness.",
    "url": "https://empowerpsychiatryil.com/resources/dementia-resources",
    "about": "Dementia",
    "provider": {
      "@type": "MedicalBusiness",
      "name": "Empower Psychiatry",
      "url": "https://empowerpsychiatryil.com",
      "telephone": "+1-630-326-3840",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "303 E Army Trail Rd, Suite 111",
        "addressLocality": "Bloomingdale",
        "addressRegion": "IL",
        "postalCode": "60108"
