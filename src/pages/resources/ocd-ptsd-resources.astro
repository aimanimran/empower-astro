import ResourcePage from '../../components/ResourcePage.astro';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "MedicalWebPage",
    "name": "OCD & PTSD",
    "description": "Educational information about obsessive thoughts, compulsive behaviors, trauma, and recovery support.",
    "url": "https://empowerpsychiatryil.com/resources/ocd-ptsd-resources",
    "about": "Obsessive-Compulsive Disorder",
    "provider": {
      "@type": "MedicalBusiness",
      "name": "Empower Psychiatry",
      "url": "https://empowerpsychiatryil.com",
      "telephone": "+1-630-326-3840",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "303 E Army Trail Rd, Suite 111",
        "addressLocality": "Bloomingdale",
        "addressRegion": "IL",
        "postalCode": "60108"
