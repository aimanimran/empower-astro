---
import ResourcePage from '../../components/ResourcePage.astro';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "MedicalWebPage",
    "name": "Autism Spectrum Disorder",
    "description": "Resources for developmental concerns, sensory differences, social communication, and family support.",
    "url": "https://empowerpsychiatryil.com/resources/autism-resources",
    "about": "Autism Spectrum Disorder",
    "provider": {
      "@type": "MedicalBusiness",
      "name": "Empower Psychiatry",
      "url": "https://empowerpsychiatryil.com",
      "telephone": "+1-630-326-3840",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "303 E Army Trail Rd, Suite 111",
        "addressLocality": "Bloomingdale",
        "addressRegion": "IL",
        "postalCode": "60108"
      }
    }
  }
];
---

<ResourcePage
  title="Autism Spectrum Disorder"
  description="Resources for developmental concerns, sensory differences, social communication, and family support."
  jsonLd={jsonLd}
>
<article class="resource-main-content reveal">

            <h2>Understanding Autism Spectrum Disorder</h2>

            <p>
              Autism Spectrum Disorder (ASD) is a neurodevelopmental condition that affects communication, social
              interaction, sensory processing, and behavioral patterns. Autism exists on a spectrum, meaning individuals
              may experience a wide range of strengths, challenges, and support needs.
            </p>

            <p>
              Many autistic individuals have unique ways of processing information, expressing emotions, and interacting
              with the world around them. Early identification and supportive interventions can improve communication,
              emotional wellbeing, academic success, and daily functioning.
            </p>

            <h2>Common Signs and Characteristics</h2>

            <ul class="resource-list">
              <li>Differences in social communication or interaction</li>
              <li>Repetitive behaviors or focused interests</li>
              <li>Sensory sensitivities to sound, texture, light, or touch</li>
              <li>Difficulty with transitions or changes in routine</li>
              <li>Speech or language development differences</li>
              <li>Emotional regulation challenges</li>
              <li>Strong attention to detail or specialized interests</li>
            </ul>

            <h2>Support and Treatment</h2>

            <p>
              Support plans for autism are highly individualized and may include behavioral therapy, speech therapy,
              occupational therapy, social skills support, educational accommodations, and psychiatric care when needed.
              Many individuals also benefit from sensory accommodations and structured routines.
            </p>

            <p>
              Families often benefit from coordinated care and community support services. Building an environment that
              emphasizes acceptance, communication, emotional safety, and individualized strengths can help autistic
              individuals thrive.
            </p>

            <h2>Local and Educational Support</h2>

            <p>
              Families in the Addison and greater DuPage County area may benefit from school-based services, early
              intervention programs, and developmental specialists throughout the Chicagoland region. Working
              collaboratively with pediatricians, therapists, schools, and mental health providers can improve long-term
              support and continuity of care.
            </p>

          </article>

          <aside class="resource-sidebar reveal">

            <div class="resource-sidebar-card">

              <h3>
                Trusted Organizations
              </h3>

              <ul>
                <li><a href="https://autismsociety.org/" target="_blank" rel="noopener noreferrer">Autism Society</a>
                </li>
                <li><a href="https://www.cdc.gov/autism/" target="_blank" rel="noopener noreferrer">CDC Autism
                    Information</a></li>
                <li><a href="https://www.dhs.state.il.us/page.aspx?item=30321" target="_blank"
                    rel="noopener noreferrer">Illinois Early Intervention</a></li>
              </ul>

            </div>

            <div class="resource-sidebar-card">

              <h3>
                Local & Crisis Support
              </h3>

              <p>
                For urgent emotional support, call or text 988 for the Suicide & Crisis Lifeline. Residents in Addison,
                Bloomingdale, DuPage County, and the greater Chicagoland area may also benefit from local counseling
                centers, hospitals, and emergency mental health services.
              </p>

            </div>

            <div class="resource-sidebar-card">

              <h3>
                When To Seek Help
              </h3>

              <p>
                Consider professional evaluation if symptoms are affecting work, school, sleep, relationships, emotional
                wellbeing, or daily functioning. Early support and treatment can improve long-term outcomes and quality
                of life.
              </p>

            </div>

          </aside>

</ResourcePage>
